#!/usr/bin/env bash
# One-shot Run for the Fastmail Connector. Wraps the Node CLI in
# `kr exec -- ...` so the project's secrets stay in this child process —
# the surrounding shell (and any coding agent in it) does not see them.
#
# Prereqs: 1Password item `pulse/FASTMAIL_API_TOKEN` tagged
# `keychain-sync`, then `kr sync` to populate the macOS Keychain.
# The project namespace comes from the repo-root `.keyring` file.

set -euo pipefail

# Run from the repo root regardless of how the script was invoked.
SCRIPT_DIR="$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
REPO_ROOT="$( cd -- "${SCRIPT_DIR}/.." &> /dev/null && pwd )"
cd "${REPO_ROOT}"

exec kr exec \
  -- pnpm --filter @pulse/connector-fastmail run sync "$@"
