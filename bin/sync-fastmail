#!/usr/bin/env bash
# One-shot Sync Run for the Fastmail Worker. Wraps the Node CLI in
# `keyring exec FASTMAIL_API_TOKEN -- ...` so the secret stays in this
# child process — the surrounding shell (and any coding agent in it)
# does not see it.
#
# Prereqs: 1Password item `cerebro/FASTMAIL_API_TOKEN` tagged
# `keychain-sync`, then `ks` to populate the macOS Keychain.
# KEYRING_PROJECT comes from .envrc.

set -euo pipefail

# Run from the repo root regardless of how the script was invoked.
SCRIPT_DIR="$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
REPO_ROOT="$( cd -- "${SCRIPT_DIR}/.." &> /dev/null && pwd )"
cd "${REPO_ROOT}"

exec keyring exec \
  FASTMAIL_API_TOKEN \
  -- pnpm --filter @cerebro/worker-fastmail run sync "$@"
